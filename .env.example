# Google Maps API Key — enables real bar suggestions via Places API
# Get one at: https://console.cloud.google.com
# Enable: Maps JavaScript API + Places API
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Microsoft Azure App Registration Client ID — enables "Sign in with Microsoft"
# Get one at: https://portal.azure.com → Azure Active Directory → App Registrations
# Set Redirect URI to: http://localhost:5173 (or your deployed URL)
# Under "Authentication" enable "Access tokens" and "ID tokens"
VITE_MS_CLIENT_ID=your_azure_app_client_id_here
